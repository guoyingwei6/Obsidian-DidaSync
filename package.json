{
    "name": "obsidian-didasync",
    "version": "1.6.0",
    "description": "Sync tasks between Dida365 or TickTick and your notes.",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "node esbuild.config.mjs production",
        "test:task-line-format": "npx tsc --module commonjs --target ES2019 --esModuleInterop --outDir .tmp-test tests/taskLineFormat.test.ts src/taskLineFormat.ts src/types.ts && node .tmp-test/tests/taskLineFormat.test.js",
        "test:task-note-block": "npx tsc --module commonjs --target ES2019 --esModuleInterop --outDir .tmp-test tests/taskNoteBlock.test.ts src/taskNoteBlock.ts src/taskNotePath.ts src/types.ts && node .tmp-test/tests/taskNoteBlock.test.js",
        "test:task-note-context": "npx tsc --module commonjs --target ES2019 --esModuleInterop --outDir .tmp-test tests/taskNoteContext.test.ts src/taskNoteContext.ts src/taskNotePath.ts src/types.ts && node .tmp-test/tests/taskNoteContext.test.js",
        "test:task-note-path": "npx tsc --module commonjs --target ES2019 --esModuleInterop --outDir .tmp-test tests/taskNotePath.test.ts src/taskNotePath.ts src/types.ts && node .tmp-test/tests/taskNotePath.test.js",
        "test:task-index": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && npx tsc --module commonjs --target ES2019 --esModuleInterop --outDir .tmp-test tests/taskIndex.test.ts src/taskIndex.ts && node .tmp-test/tests/taskIndex.test.js",
        "test:mcp": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/mcpServerManager.test.ts','src/managers/McpServerManager.ts','src/types.ts'],outdir:'.tmp-test',platform:'node',format:'cjs',bundle:false})\" && node .tmp-test/tests/mcpServerManager.test.js",
        "test:repeat-cloud-authority": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/repeatTaskCloudAuthority.test.ts','src/managers/SyncManager.ts','src/types.ts'],outdir:'.tmp-test',platform:'node',format:'cjs',bundle:false})\" && node .tmp-test/tests/repeatTaskCloudAuthority.test.js",
        "test:time-grid": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/timeGrid.test.ts'],outfile:'.tmp-test/timeGrid.test.js',platform:'node',format:'cjs',bundle:true})\" && node .tmp-test/timeGrid.test.js",
        "test:task-schedule": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/taskSchedule.test.ts'],outfile:'.tmp-test/taskSchedule.test.js',platform:'node',format:'cjs',bundle:true})\" && node .tmp-test/taskSchedule.test.js",
        "test:task-schedule-popup": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/taskSchedulePopup.test.ts'],outfile:'.tmp-test/taskSchedulePopup.test.js',platform:'node',format:'cjs',bundle:true})\" && node .tmp-test/taskSchedulePopup.test.js",
        "test:dida-api-client": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/didaApiClient.test.ts','src/api/DidaApiClient.ts','src/types.ts'],outdir:'.tmp-test',platform:'node',format:'cjs',bundle:false})\" && node .tmp-test/tests/didaApiClient.test.js",
        "test:native-task-sync": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/nativeTaskSyncManager.test.ts','src/managers/NativeTaskSyncManager.ts','src/taskLineFormat.ts'],outdir:'.tmp-test',platform:'node',format:'cjs',bundle:false})\" && node .tmp-test/tests/nativeTaskSyncManager.test.js",
        "test:task-note-sync-manager": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/taskNoteSyncManager.test.ts','src/managers/TaskNoteSyncManager.ts','src/taskNoteBlock.ts','src/taskLineFormat.ts','src/taskNoteContext.ts','src/taskNotePath.ts','src/types.ts'],outdir:'.tmp-test',platform:'node',format:'cjs',bundle:false})\" && node .tmp-test/tests/taskNoteSyncManager.test.js",
        "test:mcp-tools": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/mcpTools.test.ts','src/managers/McpServerManager.ts','src/types.ts'],outdir:'.tmp-test',platform:'node',format:'cjs',bundle:false})\" && node .tmp-test/tests/mcpTools.test.js",
        "test:project-catalog": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/projectCatalog.test.ts'],outdir:'.tmp-test',platform:'node',format:'cjs',bundle:true,external:['obsidian','electron']})\" && node .tmp-test/projectCatalog.test.js",
        "test:repeat-task-manager": "node -e \"require('fs').mkdirSync('.tmp-test',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/repeatTaskManager.test.ts','src/managers/RepeatTaskManager.ts','src/core/RRuleParser.ts','src/types.ts'],outdir:'.tmp-test',platform:'node',format:'cjs',bundle:false})\" && node .tmp-test/tests/repeatTaskManager.test.js",
        "test:utils": "npx tsc --module commonjs --target ES2019 --esModuleInterop --outDir .tmp-test tests/utils.test.ts src/utils.ts && node .tmp-test/tests/utils.test.js",
        "test:mobile-compat": "node -e \"require('fs').mkdirSync('.tmp-test/tests',{recursive:true})\" && node -e \"require('esbuild').buildSync({entryPoints:['tests/mobileCompatibility.test.ts'],outfile:'.tmp-test/tests/mobileCompatibility.test.js',platform:'node',format:'cjs',bundle:false})\" && node .tmp-test/tests/mobileCompatibility.test.js",
        "test": "npm run test:task-line-format && npm run test:task-note-block && npm run test:task-note-context && npm run test:task-note-path && npm run test:task-index && npm run test:mobile-compat && npm run test:mcp && npm run test:repeat-cloud-authority && npm run test:time-grid && npm run test:task-schedule && npm run test:task-schedule-popup && npm run test:dida-api-client && npm run test:native-task-sync && npm run test:task-note-sync-manager && npm run test:mcp-tools && npm run test:project-catalog && npm run test:repeat-task-manager && npm run test:utils",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [
        "obsidian",
        "plugin",
        "ticktick",
        "dida365"
    ],
    "author": "CYZice",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^16.11.26",
        "@typescript-eslint/eslint-plugin": "^5.29.0",
        "@typescript-eslint/parser": "^5.29.0",
        "esbuild": "0.17.3",
        "obsidian": "latest",
        "tslib": "2.4.0",
        "typescript": "4.9.5"
    },
    "dependencies": {
        "date-fns": "^2.30.0"
    }
}
